@using Jx.Cms.Common.Utils
@using Jx.Cms.DbContext
@using Jx.Cms.DbContext.Entities.Admin
@using Jx.Cms.Install.ViewModel
@using Jx.Cms.Plugin.Service.Admin
@using Mapster
@inject NavigationManager NavigationManager
@inject IAdminUserService AdminUserService
@inject SwalService SwalService

<GroupBox class="install_content">
    <div class="text-center">
        <h2>@Content</h2>
    </div>
    @if (_isFinish)
    {
        <CountDown CountDownSecond="3" OnTimeout="@OnTimeout"></CountDown>
    }

</GroupBox>

@code {

    [Parameter] public DbConfig DbConfig { get; set; }

    [Parameter] public InstallInfoVm InstallInfoVm { get; set; }

    private bool _isFinish;

    private string? Content { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Content = "正在创建管理员账户，请稍后...";
            StateHasChanged();

            try
            {
                // 创建管理员账户
                AdminUserService.Register(InstallInfoVm.Adapt<AdminUserEntity>());

                // 创建安装锁定文件
                File.Create(Path.Combine(AppContext.BaseDirectory, "config", "install.lock"));

                // 设置系统已安装标志
                Util.IsInstalled = true;

                _isFinish = true;
                Content = "安装完成，3秒后将跳转登录页面";
            }
            catch (Exception ex)
            {
                await SwalService.Show(new SwalOption
                {
                    Category = SwalCategory.Error,
                    Title = "安装失败",
                    Content = $"创建管理员账户失败: {ex.Message}"
                });
                Content = "安装失败，请检查日志";
            }

            StateHasChanged();
        }
    }

    private Task OnTimeout()
    {
        NavigationManager.NavigateTo("/Admin");
        return Task.CompletedTask;
    }

}