@using Jx.Cms.Install.ViewModel
@using Jx.Cms.Install.Validator
@using Jx.Cms.DbContext.Entities.Admin
@using Jx.Cms.Plugin.Service.Admin
@using Mapster
@inherits StepBase

<ValidateForm Model="@InstallInfoVm" OnValidSubmit="@OnSubmit">
    <GroupBox class="install_content">
        <div class="row g-3">
            <div class="form-group col-12">
                <BootstrapInput @bind-Value="@InstallInfoVm.UserName" DisplayText="管理员用户名"></BootstrapInput>
            </div>
            <div class="form-group col-12">
                <BootstrapInput @bind-Value="@InstallInfoVm.Email" DisplayText="邮箱"></BootstrapInput>
            </div>
            <div class="form-group col-12">
                <BootstrapInput @bind-Value="@InstallInfoVm.NickName" DisplayText="昵称"></BootstrapInput>
            </div>
            <div class="form-group col-12">
                <BootstrapInput @bind-Value="@InstallInfoVm.Password" DisplayText="管理员密码" type="password"></BootstrapInput>
            </div>
            <div class="form-group col-12">
                <BootstrapInput @bind-Value="@InstallInfoVm.RePassword" DisplayText="管理员密码重复" type="password" ValidateRules="@Validators">
                </BootstrapInput>
            </div>
        </div>
    </GroupBox>
    <div class="text-center">
        <Button Text="上一步" OnClick="() => Prev?.Invoke()"></Button>
        <Button ButtonType="ButtonType.Submit" IsAsync="true">确认</Button>
    </div>
</ValidateForm>

@code {
    [Parameter]
    public InstallInfoVm InstallInfoVm { get; set; }

    private List<IValidator> Validators { get; set; } = new List<IValidator>() { new InstallValidator() };

    private Task OnSubmit(EditContext arg)
    {
        Next?.Invoke();
        return Task.CompletedTask;
    }
}