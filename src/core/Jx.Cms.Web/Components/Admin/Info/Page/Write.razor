@page "/Admin/Page/Write"
@page "/Admin/Page/Write/{Id:int}"
@using System.Security.Claims
@using System.Text
@using Jx.Cms.Common.Attribute
@using Jx.Cms.Common.Enum
@using Jx.Cms.Common.Vo
@using Jx.Cms.DbContext.Entities.Article
@using Jx.Cms.Plugin.Cache
@using Jx.Cms.Plugin.Components
@using Jx.Cms.Plugin.Model
@using Jx.Cms.Plugin.Plugin
@using Jx.Cms.Plugin.Service.Admin
@using Jx.Cms.Plugin.Service.Both
@using Jx.Cms.Plugin.Utils
@using Jx.Cms.Themes.Vm
@using Jx.Toolbox.Extensions

@inject NavigationManager NavigationManager
@inject IPageService PageService
@inject ToastService ToastService
@inject DialogService DialogService
@inject PluginDialogService PluginDialogService
@inject IHttpContextAccessor HttpContextAccessor
@inject IAdminUserService AdminUserService
@inject IServiceProvider ServiceProvider

@attribute [Menu("A0259D93-39EB-462B-A69F-13924963D6AE", "创建页面", "Admin/Page/Write", 5, parentId: MenuIds.PageId)]

<ValidateForm class="row" Model="Article" OnValidSubmit="@OnValidSubmit">
    <div class="col-lg-9 col-md-8">
        <Card IsShadow="true">
            <BodyTemplate>
                <div class="row g-3">
                    <div class="col-12">
                        <BootstrapInput placeholder="请输入标题" @bind-Value="@Article.Title" DisplayText="页面标题"
                                        ShowLabel="true"></BootstrapInput>
                    </div>

                    <div class="col-12">
                        <BootstrapInput @bind-Value="@Article.Alias" DisplayText="别名" ShowLabel="true"></BootstrapInput>
                    </div>

                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">页面内容</label>
                            <div class="d-flex align-items-center gap-2 flex-nowrap">
                                <Button OnClick="AddMedia" Icon="fa fa-image" Text="添加媒体" Size="Size.Small"
                                        Color="Color.Info" Class="text-nowrap px-3"></Button>
                                <Switch @bind-Value="@Article.IsMarkdown" OnColor="Color.Success" OnText="Markdown"
                                        OffText="富文本" ShowLabel="false" OnValueChanged="OnValueChanged"></Switch>
                            </div>
                        </div>

                        @if (Article.IsMarkdown)
                        {
                            <Markdown @ref="_markdown" Language="zh-CN" Height="500" @bind-Value="@Article.MarkdownContent"
                                      @bind-Html="@Article.Content"></Markdown>
                        }
                        else
                        {
                            <Editor @ref="_editor" IsEditor="true" Height="500" @bind-Value="@Article.Content" ShowSubmit="false"
                                    CustomerToolbarButtons="@ToolbarButtons" OnClickButton="@OnClickButton"></Editor>
                        }
                    </div>

                    <div class="col-12">
                        <Textarea @bind-Value="@Article.Description" DisplayText="摘要" ShowLabel="true" rows="3"></Textarea>
                    </div>
                </div>
            </BodyTemplate>
        </Card>

        @foreach (var extModel in BottomExt)
        {
            <Card Class="mt-3" IsShadow="true">
                <HeaderTemplate>@extModel.DisplayName</HeaderTemplate>
                <BodyTemplate>
                    @RenderExt(extModel)
                </BodyTemplate>
            </Card>
        }
    </div>
    <div class="col-lg-3 col-md-4">
        <Card IsShadow="true">
            <HeaderTemplate>发布设置</HeaderTemplate>
            <BodyTemplate>
                <div class="d-grid gap-3">
                    <Button IsBlock="true" ButtonType="ButtonType.Submit" Icon="fa fa-save" Text="保存页面" Color="Color.Primary"></Button>
                    <Select Items="ArticleStatus" @bind-Value="Article.Status" DisplayText="状态" ShowLabel="true"></Select>
                    <DateTimePicker TValue="DateTime" ShowSidebar="true" @bind-Value="@Article.PublishTime"
                                    DisplayText="发布时间" ShowLabel="true" ViewModel="DatePickerViewModel.DateTime"/>
                </div>
            </BodyTemplate>
        </Card>

        @foreach (var extModel in RightExt)
        {
            <Card Class="mt-3" IsShadow="true">
                <HeaderTemplate>@extModel.DisplayName</HeaderTemplate>
                <BodyTemplate>
                    @RenderExt(extModel)
                </BodyTemplate>
            </Card>
        }
    </div>
</ValidateForm>

@code {
    [Parameter] public int Id { get; set; }

    private Editor _editor;
    private Markdown _markdown;

    private ArticleEntity Article { get; set; }

    private IEnumerable<SelectedItem> ArticleStatus { get; } = typeof(ArticleStatusEnum).ToSelectList();

    private List<EditorExtModel> EditorExtModels { get; set; }
    private List<EditorToolbarButton> ToolbarButtons { get; set; }

    private IEnumerable<IArticlePlugin> ArticlePlugins { get; set; }
    private IEnumerable<ArticleExtModel> BottomExt { get; set; }
    private IEnumerable<ArticleExtModel> RightExt { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        var settingsVm = SystemSettingsVm.Init();
        ArticlePlugins = ArticlePluginCache.GetArticlePlugins().ToList();
        EditorExtModels = PluginUtil.OnArticleEditorShow(ArticlePlugins, ServiceProvider);
        ToolbarButtons = EditorExtModels.Select(x => x.ToolbarButton).ToList();
        Article = Id == 0
            ? new ArticleEntity
            {
                IsPage = true,
                PublishTime = DateTime.Now,
                Status = ArticleStatusEnum.Published,
                IsMarkdown = settingsVm.EditWithMarkdown
            }
            : PageService.GetPageById(Id);
        Article ??= new ArticleEntity();
        Article.IsPage = true;
        Article.Metas = NormalizeMetas(Article.Metas);
        BottomExt = PluginUtil.GetBottomExtModels(ArticlePlugins, Article);
        RightExt = PluginUtil.GetRightExtModels(ArticlePlugins, Article);
    }

    private async Task OnValidSubmit(EditContext arg)
    {
        var userName = HttpContextAccessor?.HttpContext?.User?.FindFirstValue(ClaimTypes.Name);
        Article.Author = userName != null ? AdminUserService?.GetUserByUserName(userName)?.NickName ?? "" : "";

        if (!PluginUtil.OnContentBeforeSave(ArticlePlugins, Article, out var errorMsg))
        {
            await ToastService.Error("保存失败", errorMsg);
            return;
        }

        var ret = PageService.SavePage(Article);
        await ToastService.Show(new ToastOption
        {
            Category = ret ? ToastCategory.Success : ToastCategory.Error,
            Title = ret ? "保存成功" : "保存失败",
            Content = $"保存数据{(ret ? "成功" : "失败")}，4 秒后自动关闭"
        });
        if (ret)
        {
            var warnings = new List<string>();
            PluginUtil.OnContentSaved(ArticlePlugins, Article, warnings.Add);
            if (warnings.Count > 0)
            {
                await ToastService.Show(new ToastOption
                {
                    Category = ToastCategory.Warning,
                    Title = "插件提示",
                    Content = string.Join("；", warnings.Take(3))
                });
            }

            NavigationManager.NavigateTo("Admin/Page/All");
        }
    }

    private Task OnValueChanged(bool arg)
    {
        Article.Content = "";
        return Task.CompletedTask;
    }

    private async Task AddMedia()
    {
        IEnumerable<MediaInfoVo> ret = null;
        await DialogService.ShowModal<MediaSelectComponent>(new ResultDialogOption
        {
            Title = "请选择媒体",
            IsScrolling = true,
            Size = Size.ExtraLarge,
            ComponentParameters = new Dictionary<string, object>
            {
                { nameof(MediaSelectComponent.FileType), new[] { ".jpg", ".png", ".jpeg", ".gif", ".bmp" } },
                { nameof(MediaSelectComponent.MultSelect), true },
                { nameof(MediaSelectComponent.MediaSelected), EventCallback.Factory.Create<IEnumerable<MediaInfoVo>>(this, x => ret = x) }
            }
        });

        if (ret == null) return;

        var sb = new StringBuilder();
        foreach (var mediaInfoVo in ret)
        {
            switch (mediaInfoVo.MediaType)
            {
                case MediaTypeEnum.Image:
                    if (Article.IsMarkdown)
                    {
                        sb.Append($"![{mediaInfoVo.Name}]({mediaInfoVo.Url})");
                    }
                    else
                    {
                        sb.AppendLine($"<img src={mediaInfoVo.Url} alt={mediaInfoVo.Name}></img>");
                    }

                    break;
                case MediaTypeEnum.Video:
                    sb.AppendLine($@"<video src='{mediaInfoVo.Url}' controls='controls'>
                        您的浏览器不支持 video 标签。
                        </video>");
                    break;
                case MediaTypeEnum.Audio:
                    sb.AppendLine($@"<audio src='{mediaInfoVo.Url}'>
                        您的浏览器不支持 audio 标签。
                        </audio>");
                    break;
                case MediaTypeEnum.UnKnow:
                    sb.AppendLine(mediaInfoVo.Url);
                    break;
                default:
                    throw new ArgumentOutOfRangeException();
            }
        }

        if (Article.IsMarkdown)
        {
            await _markdown.DoMethodAsync("insertText", sb.ToString());
        }
        else
        {
            await _editor.DoMethodAsync("pasteHTML", sb.ToString());
        }
    }

    private async Task<string> OnClickButton(string arg)
    {
        var model = EditorExtModels.Find(x => x.ToolbarButton.ButtonName == arg);
        if (model == null)
        {
            return "";
        }

        var option = new ResultDialogOption();
        var type = model.OnDialogCreate(option);
        var res = await model.OnToolbarClick(await PluginDialogService.ShowModal(option, type, DialogService));
        return res;
    }

    private ArticleMetaEntity EnsureMeta(ArticleExtModel articleExtModel)
    {
        Article.Metas = NormalizeMetas(Article.Metas);

        var articleMetaEntity = Article.Metas.FirstOrDefault(x =>
            string.Equals(x.PluginName, articleExtModel.PluginName, StringComparison.Ordinal) &&
            string.Equals(x.Name, articleExtModel.Name, StringComparison.Ordinal));

        if (articleMetaEntity != null)
        {
            return articleMetaEntity;
        }

        articleMetaEntity = new ArticleMetaEntity
        {
            PluginName = articleExtModel.PluginName,
            Name = articleExtModel.Name,
            Value = articleExtModel.DefaultValue
        };

        Article.Metas.Add(articleMetaEntity);
        return articleMetaEntity;
    }

    private static bool IsValidMeta(ArticleMetaEntity meta)
    {
        return meta != null && !meta.PluginName.IsNullOrEmpty() && !meta.Name.IsNullOrEmpty();
    }

    private static List<ArticleMetaEntity> NormalizeMetas(IEnumerable<ArticleMetaEntity> metas)
    {
        if (metas == null)
        {
            return new List<ArticleMetaEntity>();
        }

        return metas
            .Where(IsValidMeta)
            .GroupBy(x => $"{x.PluginName}@@{x.Name}")
            .Select(g => g.OrderByDescending(x => x.Id).First())
            .ToList();
    }

    RenderFragment<ArticleExtModel> RenderExt => articleExtModel =>
        @<div class="row">
            <div class="form-group col-12">
                @{
                    var articleMetaEntity = EnsureMeta(articleExtModel);
                }
                @switch (articleExtModel.ArticleExtTypeEnum)
                {
                    case ArticleExtTypeEnum.Input:
                        <BootstrapInput @bind-Value="@articleMetaEntity.Value"
                                        DisplayText="@articleExtModel.DisplayName" ShowLabel="true"></BootstrapInput>
                        break;
                    case ArticleExtTypeEnum.Select:
                        <Select style="width: 100%" Items="@articleExtModel.Items.Select(x => new SelectedItem(x, x))"
                                @bind-Value="articleMetaEntity.Value"
                                DisplayText="@articleExtModel.DisplayName"></Select>
                        break;
                    case ArticleExtTypeEnum.TextArea:
                        <Textarea @bind-Value="@articleMetaEntity.Value"
                                  DisplayText="@articleExtModel.DisplayName"></Textarea>
                        break;
                }
            </div>
        </div>;
}
