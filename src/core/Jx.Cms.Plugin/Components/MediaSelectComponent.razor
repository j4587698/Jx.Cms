@using BootstrapBlazor.Components
@using Jx.Cms.Common.Enum
@using Jx.Cms.Common.Vo
@using Jx.Cms.Plugin.Service.Both
@using Mapster
@implements IResultDialog

@inject ToastService ToastService
@inject MessageService MessageService
@inject IMediaService MediaService

<Row>
    <ButtonUpload TValue="string" BrowserButtonText="上传新媒体文件" IsMultiple="true" ShowProgress="true"
                  OnChange="@OnClickToUpload" OnDelete="@(fileName => Task.FromResult(true))"></ButtonUpload>
</Row>

<div class="row">
    <div class="col-9">
        <Row ItemsPerRow="ItemsPerRow.One">
            已选中 @MediaInfoVos.Count(x => x.IsSelected) 个媒体文件
            <ListView TItem="MediaInfoVo" Items="@MediaInfoVos" OnListViewItemClick="OnListViewItemClick">
                <BodyTemplate>
                    <Card Color="context.IsSelected ? Color.Dark : Color.None" IsCenter="true" Class="media-list-card">
                        <HeaderTemplate>
                            <div class="media-list-name">@context.Name</div>
                        </HeaderTemplate>
                        <BodyTemplate>
                            @if (context.MediaType == MediaTypeEnum.Image)
                            {
                                <div class="media-list-thumb-wrap">
                                    <img src="@context.Url" alt="@context.Name" class="media-list-thumb"/>
                                </div>
                            }
                            else if (context.MediaType == MediaTypeEnum.Audio)
                            {
                                <div class="media-list-thumb-wrap">
                                    <i class="fa fa-file-audio-o media-list-icon"></i>
                                </div>
                            }
                            else if (context.MediaType == MediaTypeEnum.Video)
                            {
                                <div class="media-list-thumb-wrap">
                                    <i class="fa fa-file-video-o media-list-icon"></i>
                                </div>
                            }
                            else
                            {
                                <div class="media-list-thumb-wrap">
                                    <i class="fa fa-file-o media-list-icon" aria-hidden="true"></i>
                                </div>
                            }
                        </BodyTemplate>
                    </Card>
                </BodyTemplate>
            </ListView>
        </Row>
    </div>
    <div class="col-3">
        @if (SelectedMedia != null)
        {
            <Row ItemsPerRow="ItemsPerRow.One">
                <img src="@SelectedMedia.Url" class="media-preview"/>
                <BootstrapInput @bind-Value="@SelectedMedia.Name" ShowLabel="true" DisplayText="媒体名"
                                Readonly="true"></BootstrapInput>
                <BootstrapInput @bind-Value="@SelectedMedia.Url" ShowLabel="true" DisplayText="地址"
                                Readonly="true"></BootstrapInput>
                <BootstrapInput TValue="string" Value="@SelectedMedia.CreateTime.ToString("yyyy年MM月dd日")"
                                ShowLabel="true" DisplayText="媒体名" Readonly="true"></BootstrapInput>
            </Row>
        }

    </div>
</div>

<style>
    .media-list-card {
        width: 180px;
    }

    .media-list-name {
        width: 150px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .media-list-thumb-wrap {
        width: 150px;
        height: 150px;
        margin: 0 auto;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .media-list-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .media-list-icon {
        font-size: 72px;
        color: #6c757d;
    }

    .media-preview {
        width: 100%;
        max-height: 300px;
        object-fit: contain;
    }
</style>

@code {

    /// 要搜索的文件类型
    [Parameter]
    public string[] FileType { get; set; } = { ".jpg", ".jpeg", ".png", ".gif", ".mp3", ".mp4", ".wav", ".webm" };

    // 是否多项选择
    [Parameter] public bool MultSelect { get; set; } = true;

    /// 选择事件
    [Parameter]
    public EventCallback<IEnumerable<MediaInfoVo>> MediaSelected { get; set; }

    private List<MediaInfoVo> MediaInfoVos { get; set; }

    private MediaInfoVo SelectedMedia { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        MediaInfoVos = MediaService.GetMediasByExtensions(FileType).Select(x => x.Adapt<MediaInfoVo>()).ToList();
    }

    public async Task<bool> OnClosing(DialogResult result)
    {
        var ret = true;
        if (result == DialogResult.Yes && !MediaInfoVos.Any(x => x.IsSelected))
        {
            await MessageService.Show(new MessageOption
            {
                Content = "请至少选择一个媒体文件！"
            });
            ret = false;
        }

        return ret;
    }

    public async Task OnClose(DialogResult result)
    {
        if (result == DialogResult.Yes)
        {
            var selectMedia = MediaInfoVos.Where(x => x.IsSelected).ToList();

            await MediaSelected.InvokeAsync(selectMedia);
        }
    }

    private Task OnListViewItemClick(MediaInfoVo arg)
    {
        arg.IsSelected = !arg.IsSelected;
        SelectedMedia = arg.IsSelected ? arg : null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnClickToUpload(UploadFile file)
    {
        try
        {
            var fileName = file?.OriginFileName ?? "";
            var extension = Path.GetExtension(fileName);
            if (string.IsNullOrWhiteSpace(extension) ||
                !FileType.Any(x => string.Equals(x, extension, StringComparison.OrdinalIgnoreCase)))
            {
                await ToastService.Error($"不支持的文件类型，目前只支持{string.Join(",", FileType)}类型的文件");
                return;
            }

            if (!await MediaService.AddMediaAsync(file))
            {
                var error = string.IsNullOrWhiteSpace(file?.Error) ? "请检查文件格式以及服务端日志" : file.Error;
                await ToastService.Error($"文件上传失败:{error}");
                return;
            }

            MediaInfoVos = MediaService.GetMediasByExtensions(FileType).Select(x => x.Adapt<MediaInfoVo>()).ToList();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await ToastService.Error($"文件上传异常:{ex.Message}");
        }
    }

}
