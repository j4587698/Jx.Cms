@using Humanizer
@using Jx.Cms.DbContext.Entities.Admin
@using Jx.Cms.DbContext.Entities.Article
@using Jx.Toolbox.Utils
@model IEnumerable<Jx.Cms.DbContext.Entities.Article.CommentEntity>

@{
    void RenderComments(IEnumerable<CommentEntity> comments)
    {
        foreach (var comment in comments)
        {
            <li class="comment-item">
                <article>
                    <img class="avatar" src="@Avatar.GetAvatarUrl(comment.AuthorEmail)" alt="@comment.AuthorName"/>
                    <div class="comment-body">
                        <header>
                            <strong>@comment.AuthorName</strong>
                            <time datetime="@comment.CreateTime.ToString("O")">@comment.CreateTime.Humanize()</time>
                        </header>
                        <p>@comment.Content</p>
                        <a href="javascript:void(0)" data-author="@comment.AuthorName" onclick="reply('@comment.Id', this)">Reply</a>
                    </div>
                </article>
                @if (comment.Child is { Count: > 0 })
                {
                    <ol class="comment-list children">
                        @{ RenderComments(comment.Child); }
                    </ol>
                }
            </li>
        }
    }
}

<section class="comment-panel">
    <h3>Leave a Comment</h3>
    <form id="comment" method="post">
        @Html.AntiForgeryToken()
        @if (ViewData["user"] != null)
        {
            var user = ViewData["user"] as AdminUserEntity;
            <input type="hidden" name="@nameof(CommentEntity.AuthorName)" value="@user!.NickName"/>
            <input type="hidden" name="@nameof(CommentEntity.AuthorEmail)" value="@user!.Email"/>
            <input type="hidden" name="@nameof(CommentEntity.AuthorUrl)" value="@user!.HomePage"/>
            <p class="login-hint">Current user: @user.NickName</p>
        }
        else
        {
            <div class="comment-inputs">
                <label>
                    Name (required)
                    <input name="@nameof(CommentEntity.AuthorName)" type="text" value="@ViewData[nameof(CommentEntity.AuthorName)]"/>
                </label>
                <label>
                    Email (required)
                    <input name="@nameof(CommentEntity.AuthorEmail)" type="text" value="@ViewData[nameof(CommentEntity.AuthorEmail)]"/>
                </label>
                <label>
                    Website
                    <input name="@nameof(CommentEntity.AuthorUrl)" type="text" value="@ViewData[nameof(CommentEntity.AuthorUrl)]"/>
                </label>
            </div>
        }

        <input type="hidden" name="@nameof(CommentEntity.ArticleId)" value="@ViewData[nameof(CommentEntity.ArticleId)]"/>
        <input type="hidden" name="@nameof(CommentEntity.ParentId)" value="0"/>
        <span class="reply-badge" id="replyTo" style="display:none;"></span>
        <label>
            Comment
            <textarea name="@nameof(CommentEntity.Content)" rows="4"></textarea>
        </label>
        <button type="submit">Submit</button>
    </form>
</section>

<section class="comment-panel">
    <h3>Comments</h3>
    @if (Model.Any())
    {
        <ol class="comment-list">
            @{ RenderComments(Model); }
        </ol>
    }
    else
    {
        <p class="muted">No comments yet. Be the first one to leave a message.</p>
    }
</section>

<script src="/User/common.js"></script>
<script>
    function reply(id, trigger) {
        const name = trigger ? (trigger.getAttribute("data-author") || "") : "";
        const parent = document.querySelector("[name='@nameof(CommentEntity.ParentId)']");
        const badge = document.getElementById("replyTo");
        parent.value = id;
        badge.style.display = "inline-flex";
        badge.textContent = `Reply ${name} `;

        const clearButton = document.createElement("button");
        clearButton.type = "button";
        clearButton.textContent = "Cancel";
        clearButton.onclick = function () {
            parent.value = "0";
            badge.style.display = "none";
        };

        badge.appendChild(clearButton);
    }
</script>
